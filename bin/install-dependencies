#!/usr/bin/env bash

set -euo pipefail

function ensure-uv {
  # Check whether uv is globally available
  if command -v uv &> /dev/null
  then
    return 0
  fi

  # Install uv using pip (recommended installation method)
  echo "Installing uv..."
  python3 -m pip install --user uv
  
  # Add user bin to PATH if not already there
  export PATH="$HOME/.local/bin:$PATH"
}

ensure-uv

# Use uv to run conan directly - it will automatically:
# 1. Create/use a virtual environment
# 2. Install dependencies from requirements.txt
# 3. Execute the command
uv run --with-requirements requirements.txt conan install . \
  --update \
  --build=missing \
  --profile ./conanprofile \
  --profile:build ./conanprofile \
  --settings '&:build_type=Debug' \
  --output-folder=build/Debug/generators
