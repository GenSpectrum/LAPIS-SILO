{
  "testCaseName": "PhyloDescendantOf should return only descendent nodes of a given node",
  "query": "res.filter(usherTree.phyloDescendantOf('NODE_0000072')).aggregated('usherTree').orderBy('usherTree')",
  "expectedQueryResult": [
    {
      "count": 1,
      "usherTree": "key_11"
    },
    {
      "count": 1,
      "usherTree": "key_22"
    }
  ]
}
