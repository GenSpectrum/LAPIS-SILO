{
  "testCaseName": "PhyloDescendantOf should return only descendent nodes of a given node",
  "query": "default.filter(usherTree.phyloDescendantOf('NODE_0000072')).groupBy({count:=count()},{usherTree}).orderBy({usherTree})",
  "expectedQueryResult": [
    {
      "count": 1,
      "usherTree": "key_11"
    },
    {
      "count": 1,
      "usherTree": "key_22"
    }
  ]
}
