{
  "testCaseName": "MostRecentCommonAncestor query returns correct node with only missing nodes",
  "query": "default.filter((primary_key = 'key_1') || (primary_key = 'key_35')).mostRecentCommonAncestor('usherTree', printNodesNotInTree:=true).orderBy({mrcaNode})",
  "expectedQueryResult": [
    {
      "mrcaNode": null,
      "missingNodeCount": 2,
      "missingFromTree": "key_1,key_35",
      "mrcaParent": null,
      "mrcaDepth": null
    }
  ]
}
