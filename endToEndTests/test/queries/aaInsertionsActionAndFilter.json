{
  "testCaseName": "amino acid insertions action and insertion contains filter",
  "query": "res.filter(aminoAcidInsertionContains(position:=214, value:='.*PE', sequenceName:='S')).aminoAcidInsertions().orderBy('insertedSymbols', 'position')",
  "expectedQueryResult": [
    {
      "count": 1,
      "insertedSymbols": "*EPE",
